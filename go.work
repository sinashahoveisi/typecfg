// Local multi-module workspace. Versioned replace directives are required
// until github.com/sinashahoveisi/typecfg v0.1.0 is published to the module
// proxy (resilium uses use-only because its root module is already published).
// Without replace, `go build` in sources/ fails looking up the unpublished
// root module on GitHub (see CONTRIBUTING.md).
go 1.22

use (
	.
	./examples/basic
	./sources
)

replace github.com/sinashahoveisi/typecfg v0.1.0 => .

replace github.com/sinashahoveisi/typecfg/sources v0.1.0 => ./sources
